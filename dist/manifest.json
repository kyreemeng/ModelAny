{
  "manifest_version": 3,
  "name": "ModelAny",
  "version": "1.0.3",
  "description": "Ask every AI model, all at once. Type your question once and compare answers from ChatGPT, Gemini, DeepSeek, and more.",
  "permissions": [
    "storage",
    "tabGroups",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "https://www.doubao.com/*",
    "https://www.qianwen.com/*",
    "https://chat.deepseek.com/*",
    "https://www.kimi.com/*",
    "https://chatglm.cn/*",
    "https://gemini.google.com/*",
    "https://wenxin.baidu.com/*",
    "https://chat.baidu.com/*",
    "https://yiyan.baidu.com/*",
    "https://chatgpt.com/*",
    "https://www.chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://modelany.app/*"
  ],
  "action": {
    "default_title": "ModelAny",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.doubao.com/*"],
      "js": ["content-doubao.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.qianwen.com/*"],
      "js": ["content-qwen.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content-deepseek.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.kimi.com/*"],
      "js": ["content-kimi.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatglm.cn/*"],
      "js": ["content-glm.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content-gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://wenxin.baidu.com/*", "https://chat.baidu.com/*", "https://yiyan.baidu.com/*"],
      "js": ["content-wenxin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*", "https://www.chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content-chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://modelany.app/*"],
      "js": ["content-modelany-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'none'; frame-ancestors 'none'"
  }
}
